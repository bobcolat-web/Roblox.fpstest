--  LANDSCAPE AUTO-SCALING LOGIC
-- ══════════════════════════════════
local FULL_H = 600
local minimized = false
local HEADER_H = 50

-- Calculate safe max-height based on user's device (landscape mode fix)
local function adjustForLandscape()
    local viewport = ScreenGui.AbsoluteSize
    -- If screen height is small (landscape phone), shrink max height by 20px buffer
    FULL_H = math.min(600, viewport.Y - 20) 
    
    -- Center X dynamically to ensure it stays fully on screen
    if not minimized then
        MainFrame.Size = UDim2.new(0, 340, 0, FULL_H)
    end
end
-- Hook to screen size changes
ScreenGui:GetPropertyChangedSignal("AbsoluteSize"):Connect(adjustForLandscape)
adjustForLandscape() -- Run on start

