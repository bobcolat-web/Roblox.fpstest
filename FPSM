-- ══════════════════════════════════
--  MOBILE-FRIENDLY CLAMPED DRAG
-- ══════════════════════════════════
local dragging, dragStart, startPos

local function updateDrag(input)
    local delta = input.Position - dragStart
    local newX = startPos.X.Offset + delta.X
    local newY = startPos.Y.Offset + delta.Y
    
    local viewport = ScreenGui.AbsoluteSize
    
    -- Absolute bounds clamping so it cannot go off screen
    newX = math.clamp(newX, 0, viewport.X - MainFrame.AbsoluteSize.X)
    newY = math.clamp(newY, 0, viewport.Y - MainFrame.AbsoluteSize.Y)
    
    MainFrame.Position = UDim2.new(0, newX, 0, newY)
end

Header.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = {X = {Offset = MainFrame.AbsolutePosition.X}, Y = {Offset = MainFrame.AbsolutePosition.Y}}
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        updateDrag(input)
    end
end)

