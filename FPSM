MinBtn.MouseButton1Click:Connect(function()
    minimized = not minimized
    local targetH = minimized and HEADER_H or FULL_H
    
    -- Toggle visibility for internals to keep it clean
    for _, child in ipairs(MainFrame:GetChildren()) do
        if child ~= Header and child:IsA("GuiObject") and not child:IsA("UIStroke") then
            child.Visible = not minimized
        end
    end
    
    TweenService:Create(MainFrame, TweenInfo.new(0.22, Enum.EasingStyle.Quart), {Size = UDim2.new(0, 340, 0, targetH)}):Play()
    MinBtn.Text = minimized and "+" or "-"
end)

CloseBtn.MouseButton1Click:Connect(function()
    TweenService:Create(MainFrame, TweenInfo.new(0.16), { Size = UDim2.new(0, 0, 0, 0) }):Play()
    task.delay(0.18, function() ScreenGui:Destroy() end)
end)

