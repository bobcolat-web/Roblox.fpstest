local function AddToggle(text, feat)
    local b = Instance.new("TextButton", Scroll); b.Size = UDim2.new(0.9, 0, 0, 35)
    b.Font = "Code"; b.TextSize = 13; Instance.new("UICorner", b)
    local function Update()
        b.BackgroundColor3 = Features[feat] and Color3.fromRGB(0, 140, 70) or Color3.fromRGB(40, 40, 45)
        b.Text = text .. (Features[feat] and " [ON]" or " [OFF]")
