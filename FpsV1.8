-- ==========================================
-- BRUTE FORCE REVIVE ENGINE
-- ==========================================
task.spawn(function()
    while task.wait(0.1) do
        if Features.AutoRevive then
            local char = LP.Character
            -- Detect if the "Downed" UI is visible or attribute is set
            local ui = LP.PlayerGui:FindFirstChild("HUD") and LP.PlayerGui.HUD:FindFirstChild("Downed")
            local isDowned = (char and char:GetAttribute("Downed")) or (ui and ui.Visible)
            
            if isDowned then
                -- Cycle through all possible remotes used by Evade
                local events = ReplicatedStorage:FindFirstChild("Events")
                if events then
                    pcall(function() events.Respawn:FireServer() end)
                    pcall(function() events.Revive:FireServer() end)
                    -- If really stuck, fire the deploy remote
                    pcall(function() ReplicatedStorage.Events.Deploy:FireServer() end)
                end
                task.wait(1) -- Safety delay to prevent server disconnect
            end
        end
    end
end)

-- ==========================================
-- BLACK SKY NULLIFIER
-- ==========================================
RunService.Heartbeat:Connect(function()
    if Features.BlackSky then
        -- Constant override to prevent game from resetting atmosphere
        Lighting.ClockTime = 0
        Lighting.Brightness = 0
        Lighting.OutdoorAmbient = Color3.new(0,0,0)
        
        for _, obj in ipairs(Lighting:GetChildren()) do
            if obj:IsA("Atmosphere") or obj:IsA("Sky") or obj:IsA("Clouds") or obj:IsA("SunRaysEffect") then
                obj:Destroy()
                totalReaped = totalReaped + 1
            end
        end
        
        -- Create our own static sky if none exists
        if not Lighting:FindFirstChild("ZenithSky") then
            local s = Instance.new("Sky", Lighting)
            s.Name = "ZenithSky"
            s.SkyboxBk, s.SkyboxDn, s.SkyboxFt, s.SkyboxLf, s.SkyboxRt, s.SkyboxUp = "rbxassetid://0","rbxassetid://0","rbxassetid://0","rbxassetid://0","rbxassetid://0","rbxassetid://0"
            s.SunAngularSize = 0; s.MoonAngularSize = 0
        end
    end
end)

