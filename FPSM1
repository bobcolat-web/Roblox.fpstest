ExecBtn.MouseButton1Click:Connect(function()
    if boostActive then return end
    boostActive = true
    ExecBtn.Text = "APPLYING TWEAKS..."
    ExecBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    
    task.wait(0.2)
    
    if Settings.LessLighting then Lighting.GlobalShadows = false Lighting.Technology = Enum.Technology.Compatibility end
    if Settings.NoShadows then Lighting.GlobalShadows = false end
    if Settings.NoFog then Lighting.FogEnd = 100000 end
    if Settings.DisableSky then for _, v in pairs(Lighting:GetChildren()) do if v:IsA("Sky") or v:IsA("Atmosphere") then v:Destroy() end end end
    
    for _, v in pairs(workspace:GetDescendants()) do
        if Settings.MaterialMode ~= "Default" and v:IsA("BasePart") then v.Material = Enum.Material[Settings.MaterialMode] end
        if Settings.NoDecals and (v:IsA("Decal") or v:IsA("Texture")) then v.Transparency = 1 end
        if Settings.NoParticles and (v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Fire") or v:IsA("Smoke")) then v.Enabled = false end
        if Settings.LowDetailMeshes and v:IsA("MeshPart") then v.RenderFidelity = Enum.RenderFidelity.Performance end
        if Settings.NoBillboards and v:IsA("BillboardGui") then v.Enabled = false end
    end
    
    if Settings.NoWater and workspace.Terrain then
        workspace.Terrain.WaterWaveSize = 0 workspace.Terrain.WaterWaveSpeed = 0
        workspace.Terrain.WaterReflectance = 0 workspace.Terrain.WaterTransparency = 1
    end
    
    task.wait(0.3)
    ExecBtn.Text = "BOOST APPLIED!"
    ExecBtn.BackgroundColor3 = GREEN
end)

