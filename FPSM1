local matBtns = {}
local function MakeMatBtn(name, isDefault)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(0, 106, 1, 0)
    b.BackgroundColor3 = isDefault and STR_ON or BG_BTN
    b.Text = name
    b.TextColor3 = isDefault and Color3.new(1,1,1) or TXT_MAIN
    b.TextSize = 12
    b.Font = Enum.Font.GothamBold
    b.Parent = MatContainer
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 6)

    b.MouseButton1Click:Connect(function()
        Settings.MaterialMode = name
        for _, btn in pairs(matBtns) do
            TweenService:Create(btn, TweenInfo.new(0.2), {
                BackgroundColor3 = (btn == b) and STR_ON or BG_BTN,
                TextColor3 = (btn == b) and Color3.new(1,1,1) or TXT_MAIN
            }):Play()
        end
    end)
    table.insert(matBtns, b)
end
