local function AddToggle(text, feat)
    local b = Instance.new("TextButton", ScrollFrame)
    b.Size = UDim2.new(0.9, 0, 0, 30)
    b.Font = Enum.Font.Code
    b.TextSize = 14
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 4)

    local function Update()
        b.BackgroundColor3 = Features[feat] and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(60, 60, 70)
        b.Text = text .. (Features[feat] and " [ON]" or " [OFF]")
    end
    
    b.MouseButton1Click:Connect(function()
        Features[feat] = not Features[feat]
        Update()
    end)
    Update()
end

