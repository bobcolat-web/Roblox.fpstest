-- Cache System: Prevents GetDescendants() lag spikes
local CachedParts = {}

local function CacheObject(obj)
    if obj:IsA("BasePart") then
        CachedParts[obj] = true
    end
end

for _, obj in ipairs(workspace:GetDescendants()) do
    CacheObject(obj)
end

workspace.DescendantAdded:Connect(function(obj)
    CacheObject(obj)
    -- Instant Reap check for newly added things
    if Features.StripAll and (obj:IsA("Accessory") or obj:IsA("Clothing") or obj:IsA("Trail") or obj:IsA("Texture")) then
        task.defer(function() 
            pcall(function() obj:Destroy() end) 
            totalReaped = totalReaped + 1 
        end)
    end
end)

workspace.DescendantRemoving:Connect(function(obj)
    if CachedParts[obj] then CachedParts[obj] = nil end
end)

-- ENGINE ALPHA: Stats & FPS (Optimized to avoid logic calculation on RenderStepped)
local lastTick = tick()
local frameCount = 0

RunService.RenderStepped:Connect(function()
    frameCount = frameCount + 1
    local currentTick = tick()
    
    if currentTick - lastTick >= 1 then
        if Features.ShowStats then
            FPSLabel.Text = "FPS: " .. math.floor(frameCount / (currentTick - lastTick))
            DataLabel.Text = "REAPED: " .. totalReaped
        end
        frameCount = 0
        lastTick = currentTick
    end
    StatsFrame.Visible = Features.ShowStats
end)

