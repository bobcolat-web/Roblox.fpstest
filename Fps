                            t:Stop(0) 
                        end 
                    end
                end
            end
        end
    end
end)

-- ENGINE GAMMA: Culling System (Uses Cache to prevent memory leaks)
task.spawn(function()
    while task.wait(0.2) do
        local char = LP.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        
        if root then
            local rPos = root.Position
            local yields = 0
            
            -- Map Culling using Cache (No new tables created)
            for v, _ in pairs(CachedParts) do
                -- Yield every 300 parts to maintain 60FPS
                yields = yields + 1
                if yields % 300 == 0 then RunService.Heartbeat:Wait() end
                
                if v and v.Parent and not v:FindFirstAncestor("Nextbots") then
                    local dist = (v.Position - rPos).Magnitude
                    
                    -- Only apply changes if they mismatch to save property assignment overhead
                    local targetTrans = (dist > Features.RenderDist) and 1 or 0
                    if v.Transparency ~= targetTrans then
                        v.Transparency = targetTrans
                    end
                    
                    if Features.WorldReaper and targetTrans == 0 then
                        if v.Material ~= Enum.Material.Plastic then v.Material = Enum.Material.Plastic end
                        if v.CastShadow == Features.NoShadows then v.CastShadow = not Features.NoShadows end
                    end
                end
            end
            
            -- Player Entity Culling
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LP and p.Character then
                    local pRoot = p.Character:FindFirstChild("HumanoidRootPart")
                    local pDist = pRoot and (rPos - pRoot.Position).Magnitude or 0
                    
                    local shouldHide = (pDist > Features.CullDist)
                    for _, vp in ipairs(p.Character:GetDescendants()) do
                        if vp:IsA("BasePart") and vp.Name ~= "HumanoidRootPart" then
                            vp.Transparency = shouldHide and 1 or 0
                        elseif Features.StripAll and (vp:IsA("Accessory") or vp:IsA("Clothing") or vp:IsA("Trail") or vp:IsA("Texture")) then
                            vp:Destroy()
                            totalReaped = totalReaped + 1
                        end
                    end
                end
            end
            
        end
    end
end)

