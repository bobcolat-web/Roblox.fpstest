-- CHARACTER ENGINE (HITBOX/ANIMS)
-- ==========================================
local origSizes = {}
task.spawn(function()
    while task.wait(0.5) do
        local char = LP.Character
        if char then
            if Features.MicroHitbox then
                for _, p in ipairs(char:GetChildren()) do
                    if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then
                        if not origSizes[p] then origSizes[p] = p.Size end
                        p.Size = origSizes[p] * 0.3
                    end
                end
            elseif next(origSizes) then
                for p, s in pairs(origSizes) do if p.Parent then p.Size = s end end
                table.clear(origSizes)
            end
            
            if Features.NoAnims then
                local hum = char:FindFirstChildOfClass("Humanoid")
                if hum then for _, t in ipairs(hum:GetPlayingAnimationTracks()) do t:Stop(0) end end
            end
        end
    end
end)

