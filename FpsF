end)

-- ==========================================
-- THE OPTIMIZED CULLING ENGINE (Chunked)
-- ==========================================
local CachedParts = {}
local currentIdx = 1

task.spawn(function()
    while true do
        local root = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if root and #CachedParts > 0 then
            local rPos = root.Position
            -- Process 150 parts per frame to prevent stutter
            for i = 1, 150 do
                currentIdx = (currentIdx % #CachedParts) + 1
                local v = CachedParts[currentIdx]
                if v and v.obj and v.obj.Parent then
                    local dist = (v.obj.Position - rPos).Magnitude
                    local target = (dist > Features.RenderDist) and 1 or (Features.ShowBarriers and 0 or v.orig)
                    
                    if v.obj.Transparency ~= target then v.obj.Transparency = target end
                    if Features.WorldReaper and target < 1 then
                        if v.obj.Material ~= Enum.Material.Plastic then v.obj.Material = Enum.Material.Plastic end
                    end
                end
            end
        end
        RunService.Heartbeat:Wait()
    end
end)

workspace.DescendantAdded:Connect(function(obj)
    if obj:IsA("BasePart") then
        table.insert(CachedParts, {obj = obj, orig = obj.Transparency})
    end
    if Features.StripAll and (obj:IsA("Accessory") or obj:IsA("Clothing") or obj:IsA("Trail") or obj:IsA("Texture")) then
        task.defer(function() obj:Destroy(); totalReaped = totalReaped + 1 end)
    end
end)

-- Initial Cache
for _, obj in ipairs(workspace:GetDescendants()) do 
