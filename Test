local fT, fC = 0, 0
RunService.RenderStepped:Connect(function(dt)
    fT = fT + dt
    fC = fC + 1
    if fT >= 0.5 then
        local fps = math.floor(fC / fT + 0.5)
        LiveFPS.Text = fps .. " FPS"
        if fps >= 55 then
            LiveFPS.TextColor3 = GREEN
        elseif fps >= 30 then
            LiveFPS.TextColor3 = YELLOW
        else
            LiveFPS.TextColor3 = RED
        end
        fT, fC = 0, 0
    end
end)

