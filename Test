        -- Update stroke based on whether override is active
        stroke.Color = (mode == "Default") and STR_OFF or STR_ON

        for _, d in ipairs(mBtns) do
            local active = d.key == mode
            TweenService:Create(d.f, TweenInfo.new(0.15), {
                BackgroundColor3 = active and Color3.fromRGB(0, 158, 208) or BG_BTN
            }):Play()
            d.l.TextColor3 = active and Color3.fromRGB(255, 255, 255) or TXT_SUB
            d.l.Font       = active and Enum.Font.GothamBold or Enum.Font.Gotham
        end
    end

    matRefreshCallback = SelectMode  -- expose for ResetAll

    for _, m in ipairs(modes) do
        local btn = Instance.new("TextButton")
        btn.Size             = UDim2.new(0, 106, 0, 26)
        btn.BackgroundColor3 = BG_BTN
        btn.BorderSizePixel  = 0
        btn.Text             = ""
        btn.Parent           = btnRow
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

        local lbl = Instance.new("TextLabel")
        lbl.Size                  = UDim2.new(1, 0, 1, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text                  = m.label
        lbl.TextColor3            = TXT_SUB
        lbl.TextSize              = 10
        lbl.Font                  = Enum.Font.Gotham
        lbl.Parent                = btn

        table.insert(mBtns, { key = m.key, f = btn, l = lbl })
        btn.MouseButton1Click:Connect(function() SelectMode(m.key) end)
    end

    SelectMode("Default")
end

