    stroke.Thickness = 1
    stroke.Parent    = card

    local hdrLbl = Instance.new("TextLabel")
    hdrLbl.Size                  = UDim2.new(0, 100, 0, 18)
    hdrLbl.Position              = UDim2.new(0, 12, 0, 8)
    hdrLbl.BackgroundTransparency = 1
    hdrLbl.Text                  = "FPS CAP"
    hdrLbl.TextColor3            = TXT_MAIN
    hdrLbl.TextSize              = 12
    hdrLbl.Font                  = Enum.Font.GothamSemibold
    hdrLbl.TextXAlignment        = Enum.TextXAlignment.Left
    hdrLbl.Parent                = card

    local curLbl = Instance.new("TextLabel")
    curLbl.Size                  = UDim2.new(0, 90, 0, 18)
    curLbl.Position              = UDim2.new(1, -102, 0, 8)
    curLbl.BackgroundTransparency = 1
    curLbl.Text                  = "60 FPS"
    curLbl.TextColor3            = ACCENT
    curLbl.TextSize              = 12
    curLbl.Font                  = Enum.Font.GothamBold
    curLbl.TextXAlignment        = Enum.TextXAlignment.Right
    curLbl.Parent                = card

    local btnRow = Instance.new("Frame")
    btnRow.Size                  = UDim2.new(1, -24, 0, 32)
    btnRow.Position              = UDim2.new(0, 12, 0, 36)
    btnRow.BackgroundTransparency = 1
    btnRow.Parent                = card

    local bLayout = Instance.new("UIListLayout")
    bLayout.FillDirection     = Enum.FillDirection.Horizontal
    bLayout.Padding           = UDim.new(0, 5)
    bLayout.VerticalAlignment = Enum.VerticalAlignment.Center
    bLayout.Parent            = btnRow

    local caps = {60, 120, 240, 360, 480}
    local btns = {}

    local function SelectCap(cap)
        Settings.FPSCap = cap
        curLbl.Text = cap .. " FPS"
        for _, d in ipairs(btns) do
            local active = d.cap == cap
            TweenService:Create(d.f, TweenInfo.new(0.15), {
                BackgroundColor3 = active and Color3.fromRGB(0, 158, 208) or BG_BTN
            }):Play()
            d.l.TextColor3 = active and Color3.fromRGB(255, 255, 255) or TXT_SUB
            d.l.Font       = active and Enum.Font.GothamBold or Enum.Font.Gotham
        end
    end

    for _, cap in ipairs(caps) do
        local btn = Instance.new("TextButton")
        btn.Size             = UDim2.new(0, 52, 0, 28)
        btn.BackgroundColor3 = BG_BTN
        btn.BorderSizePixel  = 0
        btn.Text             = ""
        btn.Parent           = btnRow
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

        local lbl = Instance.new("TextLabel")
        lbl.Size                  = UDim2.new(1, 0, 1, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text                  = tostring(cap)
        lbl.TextColor3            = TXT_SUB
        lbl.TextSize              = 11
        lbl.Font                  = Enum.Font.Gotham
        lbl.Parent                = btn

        table.insert(btns, { cap = cap, f = btn, l = lbl })
        btn.MouseButton1Click:Connect(function() SelectCap(cap) end)
    end

    SelectCap(60)
end

