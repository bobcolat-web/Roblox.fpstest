-- FPS cap  (supports setfpscap / syn.setfpscap / Drawing.new fallbacks)
local function DoFPSCap()
    pcall(function()
        if setfpscap then
            setfpscap(Settings.FPSCap)
        elseif rawget(_G, "syn") and syn.setfpscap then
            syn.setfpscap(Settings.FPSCap)
        end
    end)
end

-- Material override with per-part backup
local function DoMaterial()
    local mode = Settings.MaterialMode
    if mode == "Default" then return end

    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and not v:IsA("Terrain") then
            pcall(function()
                -- Backup original only once
                if not Originals.Parts[v] then
                    Originals.Parts[v] = {
                        Material  = v.Material,
                        CastShadow = v.CastShadow,
                    }
                end
                if mode == "Studs" then
                    v.Material = Enum.Material.SmoothPlastic
                    -- Remove special mesh textures
                    for _, c in ipairs(v:GetChildren()) do
                        if c:IsA("SpecialMesh") then
                            c.TextureId = ""
                        end
                    end
                elseif mode == "SmoothPlastic" then
                    v.Material = Enum.Material.SmoothPlastic
                end
            end)
        end
    end

    -- Also handle Studs-specific: force texture-less SpecialMeshes everywhere
    if mode == "Studs" then
        for _, v in ipairs(workspace:GetDescendants()) do
            if v:IsA("SpecialMesh") then
                pcall(function() v.TextureId = "" end)
            end
        end
    end
end

local function DoLighting()
    if not Settings.LessLighting then return end
    Originals.Brightness = Lighting.Brightness
    Originals.Ambient    = Lighting.Ambient
    Originals.OutdoorAmb = Lighting.OutdoorAmbient
    pcall(function()
        Lighting.Brightness     = 0.35
        Lighting.Ambient        = Color3.fromRGB(85, 85, 85)
        Lighting.OutdoorAmbient = Color3.fromRGB(85, 85, 85)
    end)
    for _, e in ipairs(Lighting:GetChildren()) do
        pcall(function()
            if  e:IsA("BloomEffect")
             or e:IsA("DepthOfFieldEffect")
             or e:IsA("SunRaysEffect")
             or e:IsA("ColorCorrectionEffect")
             or e:IsA("BlurEffect")
             or e:IsA("GlassEffect") then
                e.Enabled = false
            end
        end)
    end
end

local function DoParticles()
    if not Settings.NoParticles then return end
    local function KillParticle(v)
        if v:IsA("ParticleEmitter") or v:IsA("Smoke")
        or v:IsA("Fire")            or v:IsA("Sparkles") then
            pcall(function() v.Enabled = false end)
        end
    end
    for _, v in ipairs(workspace:GetDescendants()) do KillParticle(v) end
    -- Live watcher for newly-added particles
    if not particleWatcher then
        particleWatcher = workspace.DescendantAdded:Connect(function(v)
            if Settings.NoParticles then task.defer(KillParticle, v) end
        end)
    end
end

local function DoShadows()
    if not Settings.NoShadows then return end
    Originals.GlobalShadows = Lighting.GlobalShadows
    pcall(function() Lighting.GlobalShadows = false end)
end

local function DoFog()
    if not Settings.NoFog then return end
    Originals.FogEnd   = Lighting.FogEnd
    Originals.FogStart = Lighting.FogStart
    pcall(function()
        Lighting.FogEnd   = 100000
        Lighting.FogStart = 99998
    end)
end

local function DoDecals()
    if not Settings.NoDecals then return end
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("Decal") or v:IsA("Texture") then
            pcall(function() v.Transparency = 1 end)
        end
    end
end

local function DoSky()
    if not Settings.DisableSky then return end
    for _, v in ipairs(Lighting:GetChildren()) do
        if v:IsA("Sky") then pcall(function() v:Destroy() end) end
    end
end

local function DoWater()
    if not Settings.NoWater then return end
    pcall(function()
        workspace.Terrain.WaterWaveSize    = 0
        workspace.Terrain.WaterWaveSpeed   = 0
        workspace.Terrain.WaterReflectance = 0
    end)
end

local function DoRenderDist()
    if not Settings.LowRenderDist then return end
    pcall(function()
        workspace.StreamingMinRadius    = 32
        workspace.StreamingTargetRadius = 64
    end)
end

local function DoSounds()
    if not Settings.MinimizeSound then return end
    pcall(function() SoundService.AmbientReverb = Enum.ReverbType.NoReverb end)
    local char = LocalPlayer.Character
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("Sound") then
            pcall(function()
                if char and v:IsDescendantOf(char) then return end
                v.Volume = math.min(v.Volume, 0.08)
            end)
        end
    end
end

local function DoAnimations()
    if not Settings.NoAnimations then return end
    local char = LocalPlayer.Character
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("Animator") then
            pcall(function()
                if char and v:IsDescendantOf(char) then return end
                for _, track in ipairs(v:GetPlayingAnimationTracks()) do
                    track:Stop(0)
                end
            end)
        end
    end
end

local function DoMeshLOD()
    if not Settings.LowDetailMeshes then return end
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("MeshPart") then
            pcall(function() v.RenderFidelity = Enum.RenderFidelity.Automatic end)
        end
    end
end

-- Additional features
local function DoBillboards()
    if not Settings.NoBillboards then return end
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("BillboardGui") or v:IsA("SurfaceGui") then
            pcall(function() v.Enabled = false end)
        end
    end
end

local function DoFreezeBG()
    if not Settings.FreezeBG then return end
    local char = LocalPlayer.Character
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("Humanoid") then
            pcall(function()
                if char and v:IsDescendantOf(char) then return end
                v.WalkSpeed  = 0
                v.JumpHeight = 0
            end)
        end
    end
end

local function DoFOV()
    if not Settings.MaxFOV then return end
    local cam = workspace.CurrentCamera
    if cam then
        Originals.CameraFOV = cam.FieldOfView
        pcall(function() cam.FieldOfView = 120 end)
    end
end

-- ══════════════════════════════════
--  FULL RESET
-- ══════════════════════════════════
local function ResetAll()
    -- FPS uncap
    pcall(function() if setfpscap then setfpscap(0) end end)

    -- Restore lighting
    pcall(function()
        Lighting.GlobalShadows  = Originals.GlobalShadows
        Lighting.Brightness     = Originals.Brightness
        Lighting.Ambient        = Originals.Ambient
        Lighting.OutdoorAmbient = Originals.OutdoorAmb
        Lighting.FogEnd         = Originals.FogEnd
        Lighting.FogStart       = Originals.FogStart
    end)
    for _, e in ipairs(Lighting:GetChildren()) do
        pcall(function()
            if  e:IsA("BloomEffect") or e:IsA("DepthOfFieldEffect")
             or e:IsA("SunRaysEffect") or e:IsA("ColorCorrectionEffect")
             or e:IsA("BlurEffect") then
                e.Enabled = true
            end
        end)
    end

    -- Restore part materials
    for part, data in pairs(Originals.Parts) do
        pcall(function()
            if part and part.Parent then
                part.Material   = data.Material
                part.CastShadow = data.CastShadow
            end
        end)
    end
    Originals.Parts = {}

    -- Restore particles
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("ParticleEmitter") or v:IsA("Smoke")
        or v:IsA("Fire")            or v:IsA("Sparkles") then
            pcall(function() v.Enabled = true end)
        end
    end
    if particleWatcher then particleWatcher:Disconnect(); particleWatcher = nil end

    -- Restore workspace billboards (only if NoBillboards was active)
    if Settings.NoBillboards then
        for _, v in ipairs(workspace:GetDescendants()) do
            if v:IsA("BillboardGui") or v:IsA("SurfaceGui") then
                pcall(function() v.Enabled = true end)
            end
        end
    end

    -- Restore sounds
    pcall(function() SoundService.AmbientReverb = Originals.AmbientReverb end)

    -- Restore FOV
    if Originals.CameraFOV then
        pcall(function()
            local cam = workspace.CurrentCamera
            if cam then cam.FieldOfView = Originals.CameraFOV end
        end)
        Originals.CameraFOV = nil
    end

    -- Reset material selector UI
    if matRefreshCallback then matRefreshCallback("Default") end
    Settings.MaterialMode = "Default"

    -- Reset all boolean toggles
    for k in pairs(Settings) do
        if k ~= "FPSCap" and k ~= "MaterialMode" then
            Settings[k] = false
            local r = toggleRefs[k]
            if r then
                TweenService:Create(r.bg, TweenInfo.new(0.18), { BackgroundColor3 = Color3.fromRGB(24, 24, 40) }):Play()
                TweenService:Create(r.knob, TweenInfo.new(0.18), {
                    Position         = UDim2.new(0, 3, 0.5, -8),
                    BackgroundColor3 = Color3.fromRGB(50, 50, 78),
                }):Play()
                r.stroke.Color = STR_OFF
            end
        end
    end

    -- Reset exec button
    boostActive      = false
    ExecGrad.Enabled = true
    ExecLbl.Text     = "⚡   EXECUTE BOOST"
    TweenService:Create(ExecBtn, TweenInfo.new(0.2), { BackgroundColor3 = Color3.fromRGB(0, 160, 210) }):Play()
    SDot.BackgroundColor3 = Color3.fromRGB(48, 56, 90)
    StatusLbl.TextColor3  = TXT_SUB
    StatusLbl.Text        = "Reset, all settings cleared"
end

