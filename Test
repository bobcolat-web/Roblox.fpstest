-- Standard on/off toggle row
local function MakeToggle(label, desc, key, defaultState)
    if defaultState == nil then defaultState = false end

    local card = Instance.new("Frame")
    card.Name             = "Toggle_" .. key
    card.Size             = UDim2.new(1, -28, 0, 56)
    card.BackgroundColor3 = BG_CARD
    card.BorderSizePixel  = 0
    card.LayoutOrder      = LO()
    card.Parent           = Scroll
    Instance.new("UICorner", card).CornerRadius = UDim.new(0, 8)

    local stroke = Instance.new("UIStroke")
    stroke.Color     = STR_OFF
    stroke.Thickness = 1
    stroke.Parent    = card

    local lbl = Instance.new("TextLabel")
    lbl.Size                  = UDim2.new(1, -68, 0, 20)
    lbl.Position              = UDim2.new(0, 12, 0, 8)
    lbl.BackgroundTransparency = 1
    lbl.Text                  = label
    lbl.TextColor3            = TXT_MAIN
    lbl.TextSize              = 12
    lbl.Font                  = Enum.Font.GothamSemibold
    lbl.TextXAlignment        = Enum.TextXAlignment.Left
    lbl.Parent                = card

    local dlbl = Instance.new("TextLabel")
    dlbl.Size                  = UDim2.new(1, -68, 0, 16)
    dlbl.Position              = UDim2.new(0, 12, 0, 30)
    dlbl.BackgroundTransparency = 1
    dlbl.Text                  = desc
    dlbl.TextColor3            = TXT_SUB
    dlbl.TextSize              = 9
    dlbl.Font                  = Enum.Font.Gotham
    dlbl.TextXAlignment        = Enum.TextXAlignment.Left
    dlbl.Parent                = card

    -- Pill background
    local pillBG = Instance.new("Frame")
    pillBG.Size             = UDim2.new(0, 42, 0, 22)
    pillBG.Position         = UDim2.new(1, -54, 0.5, -11)
    pillBG.BackgroundColor3 = Color3.fromRGB(24, 24, 40)
    pillBG.BorderSizePixel  = 0
    pillBG.Parent           = card
    Instance.new("UICorner", pillBG).CornerRadius = UDim.new(1, 0)

    -- Knob
    local knob = Instance.new("Frame")
    knob.Size             = UDim2.new(0, 16, 0, 16)
    knob.Position         = UDim2.new(0, 3, 0.5, -8)
    knob.BackgroundColor3 = Color3.fromRGB(50, 50, 78)
    knob.BorderSizePixel  = 0
    knob.Parent           = pillBG
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    -- Full-card invisible click target
    local hit = Instance.new("TextButton")
    hit.Size                 = UDim2.new(1, 0, 1, 0)
    hit.BackgroundTransparency = 1
    hit.Text                 = ""
    hit.ZIndex               = 3
    hit.Parent               = card

    toggleRefs[key] = { bg = pillBG, knob = knob, stroke = stroke }

    local function Refresh(state)
        local ti = TweenInfo.new(0.18, Enum.EasingStyle.Quad)
        if state then
            TweenService:Create(pillBG, ti, { BackgroundColor3 = Color3.fromRGB(0, 158, 208) }):Play()
            TweenService:Create(knob,   ti, {
                Position         = UDim2.new(0, 23, 0.5, -8),
                BackgroundColor3 = Color3.fromRGB(255, 255, 255),
            }):Play()
            stroke.Color = STR_ON
        else
            TweenService:Create(pillBG, ti, { BackgroundColor3 = Color3.fromRGB(24, 24, 40) }):Play()
            TweenService:Create(knob,   ti, {
                Position         = UDim2.new(0, 3, 0.5, -8),
                BackgroundColor3 = Color3.fromRGB(50, 50, 78),
            }):Play()
            stroke.Color = STR_OFF
        end
    end

    hit.MouseButton1Click:Connect(function()
        Settings[key] = not Settings[key]
        Refresh(Settings[key])
    end)

    Refresh(Settings[key])
    return Refresh  -- return so caller can trigger it externally
end

-- FPS cap selector
local function MakeFPSSelector()
    local card = Instance.new("Frame")
    card.Size             = UDim2.new(1, -28, 0, 80)
    card.BackgroundColor3 = BG_CARD
    card.BorderSizePixel  = 0
    card.LayoutOrder      = LO()
    card.Parent           = Scroll
    Instance.new("UICorner", card).CornerRadius = UDim.new(0, 8)

    local stroke = Instance.new("UIStroke")
