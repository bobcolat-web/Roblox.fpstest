local isMinimized = false
local fullSize = UDim2.new(0, 340, 0, 500)
local minSize = UDim2.new(0, 340, 0, 50)

MinBtn.MouseButton1Click:Connect(function()
    isMinimized = not isMinimized
    local targetSize = isMinimized and minSize or fullSize
    
    -- Hide children to prevent visual clutter while small
    for _, child in ipairs(MainFrame:GetChildren()) do
        if child ~= Header and child:IsA("GuiObject") and not child:IsA("UIStroke") then
            child.Visible = not isMinimized
        end
    end
    
    TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {Size = targetSize}):Play()
    MinBtn.Text = isMinimized and "+" or "-"
end)

