local function CreateLabel(parent, pos, text, color)
    local lbl = Instance.new("TextLabel", parent)
    lbl.Size = UDim2.new(1, -10, 0, 20); lbl.Position = pos; lbl.Text = text
    lbl.TextColor3 = color; lbl.BackgroundTransparency = 1; lbl.Font = Enum.Font.Code; lbl.TextSize = 12
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    return lbl
end

