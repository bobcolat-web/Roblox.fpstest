-- ENGINE: DATA SAVER & PURGE (Improved)
local CachedParts = {}
local function SecureReap(obj)
    if not obj then return end
    if obj:IsA("BasePart") then
        CachedParts[obj] = true
    elseif Features.StripAll and (obj:IsA("Accessory") or obj:IsA("Clothing") or obj:IsA("Trail") or obj:IsA("Texture") or obj:IsA("Decal")) then
        totalReaped = totalReaped + 1
        obj:Destroy() -- Kills data usage instantly
    end
end

for _, v in ipairs(workspace:GetDescendants()) do SecureReap(v) end
workspace.DescendantAdded:Connect(SecureReap)
workspace.DescendantRemoving:Connect(function(v) CachedParts[v] = nil end)

-- ENGINE: ENVIRONMENT & SKY LOCK (Daylight Mode)
task.spawn(function()
    while task.wait(0.5) do
        Lighting.FogEnd = 1e6; Lighting.FogStart = 1e6 -- Kill Fog
        Lighting.ClockTime = 14; Lighting.Brightness = 3 -- Force Daylight
        Lighting.GlobalShadows = not Features.NoShadows
        
        if Features.BlackSky then
            local v = Lighting:FindFirstChild("ZenithVoid") or Instance.new("Sky", Lighting)
            v.Name = "ZenithVoid"
            v.SkyboxBk, v.SkyboxDn, v.SkyboxFt, v.SkyboxLf, v.SkyboxRt, v.SkyboxUp = "rbxassetid://0","rbxassetid://0","rbxassetid://0","rbxassetid://0","rbxassetid://0","rbxassetid://0"
            v.SunAngularSize, v.MoonAngularSize, v.StarCount = 0, 0, 0
            
            for _, s in ipairs(Lighting:GetChildren()) do
                if (s:IsA("Sky") and s.Name ~= "ZenithVoid") or s:IsA("Atmosphere") or s:IsA("Clouds") then
                    s:Destroy(); totalReaped = totalReaped + 1
                elseif s:IsA("PostEffect") then s.Enabled = false end
            end
        end
        
        if Features.NoAnims then
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LP and p.Character then
                    local h = p.Character:FindFirstChildOfClass("Humanoid")
                    local a = h and h:FindFirstChildOfClass("Animator")
                    if a then for _, t in ipairs(a:GetPlayingAnimationTracks()) do t:Stop(0) end end
                end
            end
        end
    end
end)

-- ENGINE: CULLING & PERFORMANCE (Dimensity 8200 Optimized)
task.spawn(function()
    while task.wait(0.2) do
        local root = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if root then
            local pos, count = root.Position, 0
            -- Map Culling
            for part, _ in pairs(CachedParts) do
                count = count + 1
                if count % 450 == 0 then RunService.Heartbeat:Wait() end
                
                if part and part.Parent and not part:FindFirstAncestor("Nextbots") then
                    local d = (part.Position - pos).Magnitude
                    local isFar = d > Features.RenderDist
                    if part.Transparency ~= (isFar and 1 or 0) then part.Transparency = (isFar and 1 or 0) end
                    if Features.WorldReaper and not isFar then
                        if part.Material ~= Enum.Material.Plastic then part.Material = Enum.Material.Plastic end
                        part.CastShadow = not Features.NoShadows
                    end
                end
            end
            -- Player Culling
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LP and p.Character then
                    local pR = p.Character:FindFirstChild("HumanoidRootPart")
                    local pD = pR and (pos - pR.Position).Magnitude or 0
                    local hide = pD > Features.CullDist
                    for _, vp in ipairs(p.Character:GetDescendants()) do
                        if vp:IsA("BasePart") and vp.Name ~= "HumanoidRootPart" then
                            vp.Transparency = hide and 1 or 0
                        end
                    end
                end
            end
        end
    end
end)

